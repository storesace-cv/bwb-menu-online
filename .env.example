# Database (Supabase instance menu-online)
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/postgres

# Supabase (for RPC from Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://db-menu.bwb.pt
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Obrigatória em produção para cifrar segredos (NET-BO, chaves API ChatGPT/Grok por loja e da plataforma). Mín. 32 caracteres.
# ENCRYPTION_MASTER_KEY=

# Optional: version for /api/health
COMMIT_SHA=

# Deploy (used by update.sh)
# BWB_SERVER_IP=38.19.200.55
# BWB_SERVER_HOST=38.19.200.55
# SSH key: use main-srv-01 alias or set SSH key path
