# BWB Menu Online — API Supabase (Kong) em db-menu.bwb.pt
# Todo o tráfego para 127.0.0.1:8102 (Kong).
# SSL: certbot para db-menu.bwb.pt ou cert wildcard *.bwb.pt; ajustar paths abaixo.

server {
    listen 80;
    listen [::]:80;
    server_name db-menu.bwb.pt;
    # return 301 https://$host$request_uri;
    location / {
        proxy_pass http://127.0.0.1:8102;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name db-menu.bwb.pt;
    ssl_certificate     /etc/letsencrypt/live/db-menu.bwb.pt/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/db-menu.bwb.pt/privkey.pem;
    location / {
        proxy_pass http://127.0.0.1:8102;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
