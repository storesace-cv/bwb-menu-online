# BWB Menu Online — menu.bwb.pt + *.menu.bwb.pt
# Proxy to app on 127.0.0.1:8103. API Supabase em db-menu.bwb.pt (vhost separado).
# SSL paths: adjust to your cert (certbot / wildcard DNS-01 / Cloudflare origin cert).

server {
    listen 80;
    listen [::]:80;
    server_name menu.bwb.pt *.menu.bwb.pt;
    # return 301 https://$host$request_uri;
    location / {
        client_max_body_size 10m;
        proxy_pass http://127.0.0.1:8103;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}

# SSL: certbot /etc/letsencrypt/live/menu.bwb.pt
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name menu.bwb.pt *.menu.bwb.pt;
    ssl_certificate     /etc/letsencrypt/live/menu.bwb.pt/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/menu.bwb.pt/privkey.pem;
    location / {
        client_max_body_size 10m;
        proxy_pass http://127.0.0.1:8103;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}
